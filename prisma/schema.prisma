generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                        String          @id @default(cuid())
  employeeId                String          @unique
  employeeName              String
  position                  String?
  department                String?
  email                     String?
  phone                     String?
  joinDate                  DateTime?
  status                    String?         @default("Active:Working")
  avatar                    String?
  birthDate                 DateTime?
  address                   String?
  bloodGroup                String?
  locationId                String?
  salary                    String?
  basicSalary               Float?
  attendanceAllowance       Float?
  dailyAllowance            Float?
  fuelAllowance             Float?
  conveyanceAllowance       Float?
  maintainence              Float?
  comission                 Float?
  eachKpiIncentives         Float?
  incentives                Float?
  categoryIncentive         Float?
  taxDeduction              String?
  eobiDeduction             String?
  socialSecurityDeduction   String?
  clearanceLetterUrl        String?
  cnicCopyUrl               String?
  cnicExpiryDate            DateTime?
  cnicIssueDate             DateTime?
  cnicNumber                String?
  createdAt                 DateTime        @default(now())
  cvUrl                     String?
  drivingLicenseUrl         String?
  licenseExpiryDate         DateTime?
  eduDocsUrl                String?
  emergencyContactName      String?
  emergencyContactNumber    String?
  fatherName                String?
  gender                    String?
  guaranteeChequeUrl        String?
  guarantorChequeUrl        String?
  guarantorCnicUrl          String?
  leaveDate                 DateTime?
  maritalStatus             String?
  policeCertUrl             String?
  probationConfirmationDate DateTime?
  referenceName             String?
  referenceNumber           String?
  setupName                 String?
  stampPaperUrl             String?
  updatedAt                 DateTime        @updatedAt
  utilityBillUrl            String?
  referenceEmail            String?
  userId                    String?         @unique
  bankName                  String?
  accountNumber             String?
  routeName                 String?
  advanceEligibilityAmount  Float?
  loanEligibilityAmount     Float?
  loaderAllowance           Float?
  annualLeaves              Int?
  noticePeriod              Int?            @default(0)
  salaryAllowanceDetails    Json?
  otherDocuments            Json?
  shortages                 Float?          @default(0)
  marketCredit              Float?          @default(0)
  olpersMilk                Float?          @default(0)
  olpersCareem              Float?          @default(0)
  eidIncentive              Float?          @default(0)
  olpers500ml               Float?          @default(0)
  attendances               Attendance[]
  user                      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  location                  Location?       @relation(fields: [locationId], references: [id])
  leaveRequests             LeaveRequest[]
  loans                     Loan[]
  advances                  Advance[]
  payrolls                  Payroll[]
  adminRequests             AdminRequest[]
  adjustments               EmployeeAdjustment[]
}

model User {
  id                     String         @id @default(cuid())
  email                  String         @unique
  passwordHash           String
  isActive               Boolean        @default(true)
  locationId             String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  approvedBudgets        Budget[]       @relation("BudgetApprovedBy")
  budgets                Budget[]       @relation("BudgetCreatedBy")
  approvedExpenseSheets  ExpenseSheet[] @relation("ExpenseApprovedBy")
  expenseSheets          ExpenseSheet[] @relation("ExpenseCreatedBy")
  disbursedExpenseSheets ExpenseSheet[] @relation("ExpenseDisbursedBy")
  rejectedExpenseSheets  ExpenseSheet[] @relation("ExpenseRejectedBy")
  notifications          Notification[]
  location               Location       @relation(fields: [locationId], references: [id])
  roles                  UserRole[]
  authorizedLocations    Location[]     @relation("UserAuthorizedLocations")
  employee               Employee?
}

model Role {
  id    String     @id @default(cuid())
  name  String     @unique
  users UserRole[]
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Location {
  id                    String         @id @default(cuid())
  name                  String
  city                  String
  monthlyPettyCashLimit Float?
  budgets               Budget[]
  employees             Employee[]
  expenseSheets         ExpenseSheet[]
  expenseTypes          ExpenseType[]  @relation("LocationExpenseTypes")
  routes                Route[]        @relation("RouteLocation")
  users                 User[]
  vehicles              Vehicle[]      @relation("VehicleLocation")
  authorizedUsers       User[]         @relation("UserAuthorizedLocations")
  loaderEntries         LoaderEntry[]
  loaderSummaries       LoaderDailySummary[]

  @@unique([name, city])
}

model ExpenseType {
  id                      String         @id @default(cuid())
  name                    String
  description             String?
  isActive                Boolean        @default(true)
  requiresRouteAndVehicle Boolean        @default(false)
  expenseCode             String?
  locationId              String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  expenseSheets           ExpenseSheet[]
  location                Location?      @relation("LocationExpenseTypes", fields: [locationId], references: [id])

  @@unique([name, locationId])
}

model ExpenseSheet {
  id              String              @id @default(cuid())
  details         String?
  amount          Float
  status          ExpenseStatus       @default(PENDING)
  disburseType    String              @default("Cash")
  locationId      String
  routeId         String?
  vehicleId       String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  disbursedById   String?
  disbursedAt     DateTime?
  accountTitle    String?
  accountNo       String?
  bankName        String?
  chequeDate      DateTime?
  disbursedAmount Float?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  category        String              @default("Expense")
  items           Json?
  expenseTypeEnum OldExpenseType?
  expenseTypeId   String?
  invoiceAmount   Float?
  returnAmount    Float?
  returnPercentage Float?
  rentPercentage   Float?
  attachments     ExpenseAttachment[]
  approvedBy      User?               @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  createdBy       User                @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  disbursedBy     User?               @relation("ExpenseDisbursedBy", fields: [disbursedById], references: [id])
  expenseType     ExpenseType?        @relation(fields: [expenseTypeId], references: [id])
  location        Location            @relation(fields: [locationId], references: [id])
  rejectedBy      User?               @relation("ExpenseRejectedBy", fields: [rejectedById], references: [id])
  route           Route?              @relation(fields: [routeId], references: [id])
  vehicle         Vehicle?            @relation(fields: [vehicleId], references: [id])
}

model ExpenseAttachment {
  id        String       @id @default(cuid())
  sheetId   String
  url       String
  fileKey   String
  fileName  String
  fileType  String
  fileSize  Int
  createdAt DateTime     @default(now())
  sheet     ExpenseSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attendance {
  id             String   @id @default(cuid())
  employeeId     String
  date           DateTime
  checkIn        String?
  checkOut       String?
  checkInStatus  String?
  checkOutStatus String?
  workingHours   Float?
  status         String?
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  employeeId   String
  employeeName String?
  leaveType    String?
  startDate    DateTime?
  endDate      DateTime?
  days         Int?
  reason       String?
  status       String?   @default("PENDING")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AdminRequest {
  id           String    @id @default(cuid())
  employeeId   String
  employeeName String?
  subject      String
  details      String
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Payroll {
  id                    String    @id @default(cuid())
  employeeId            String
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  month                 Int
  year                  Int
  
  basicSalary           Float?
  totalDays             Int?
  workingDays           Int?
  daysWorked            Int?
  basicPayable          Float?
  
  attendanceAllowance    Float?
  dailyAllowance         Float?
  fuelAllowance          Float?
  conveyanceAllowance    Float?
  maintainence           Float?
  comission              Float?
  eachKpiIncentives      Float?
  incentives             Float?
  loadersAllowance       Float?
  
  olpersMilk             Float?          @default(0)
  olpersCareem           Float?          @default(0)
  eidIncentive           Float?          @default(0)
  olpers500ml            Float?          @default(0)
  categoryIncentive      Float?          @default(0)

  totalIncentives        Float?
  grossSalary            Float?
  
  eobi                   Float?
  socialSecurity         Float?
  incomeTax              Float?
  advance                Float?
  loan                   Float?
  shortages              Float?    @default(0)
  marketCredit           Float?    @default(0)
  totalDeduction         Float?
  
  netSalary              Float?
  
  amount                Float     // Net Salary equivalent
  paidAt                DateTime?
  paymentMethod         String?
  status                String?   @default("Draft")
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([employeeId, month, year])
}

model EmployeeAdjustment {
  id             String    @id @default(cuid())
  employeeId     String
  month          Int
  year           Int
  incentives     Float     @default(0)
  comission              Float     @default(0)
  shortages              Float     @default(0)
  marketCredit           Float     @default(0)
  attendanceAllowance    Float?    @default(0)
  dailyAllowance         Float?    @default(0)
  fuelAllowance          Float?    @default(0)
  conveyanceAllowance    Float?    @default(0)
  maintainence           Float?    @default(0)
  eachKpiIncentives      Float?    @default(0)
  olpersMilk             Float?    @default(0)
  olpersCareem           Float?    @default(0)
  eidIncentive           Float?    @default(0)
  olpers500ml            Float?    @default(0)
  categoryIncentive      Float?    @default(0)
  createdAt              DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}

model Loan {
  id                 String    @id @default(cuid())
  employeeId         String
  principalAmount    Float
  issuedAt           DateTime?
  dueAt              DateTime?
  balance            Float?
  installments       Int?
  monthlyInstallment Float?
  status             String?
  notes              String?
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Advance {
  id                 String    @id @default(cuid())
  employeeId         String
  principalAmount    Float
  issuedAt           DateTime?
  dueAt              DateTime?
  balance            Float?
  installments       Int?
  monthlyInstallment Float?
  status             String?
  notes              String?
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Route {
  id            String         @id @default(cuid())
  routeNo       String
  name          String
  description   String?
  isActive      Boolean        @default(true)
  locationId    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenseSheets ExpenseSheet[]
  location      Location       @relation("RouteLocation", fields: [locationId], references: [id])

  @@unique([routeNo, locationId])
}

model Vehicle {
  id            String         @id @default(cuid())
  vehicleNo     String
  type          String?
  model         String?
  isActive      Boolean        @default(true)
  locationId    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenseSheets ExpenseSheet[]
  location      Location       @relation("VehicleLocation", fields: [locationId], references: [id])

  @@unique([vehicleNo, locationId])
  loaderEntries LoaderEntry[]
}

model Budget {
  id           String       @id @default(cuid())
  amount       Float
  categories   Json?
  status       BudgetStatus @default(PENDING)
  locationId   String
  createdById  String
  approvedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  month        Int          @default(2)
  year         Int          @default(2026)
  approvedBy   User?        @relation("BudgetApprovedBy", fields: [approvedById], references: [id])
  createdBy    User         @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  location     Location     @relation(fields: [locationId], references: [id])

  @@unique([locationId, month, year])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

