  PENDING
  APPROVED
  REJECTED
}

model LoaderEntry {
  id        String   @id @default(cuid())
  date      DateTime
  vehicleId String?
  vehicleNo String?
  loads     Int      @default(0)
  loaders   Int      @default(0)
  locationId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([date])
  @@index([locationId])
}

model LoaderDailySummary {
  id               String   @id @default(cuid())
  date             DateTime
  warehouseLoaders Int      @default(0)
  netWages         Float    @default(0)
  dailyWages       Float?   @default(0)
  netAttendance    Float?   @default(0)
  locationId       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  location         Location? @relation(fields: [locationId], references: [id])

  @@unique([date, locationId])
  @@index([date])
  @@index([locationId])
}
